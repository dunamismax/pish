# Pish local development reverse proxy
# In production, replace :80 with the actual domain (e.g., getpish.com)

:80 {
	# API routes
	handle /api/* {
		reverse_proxy api:3001
	}

	# WebSocket routes
	handle /ws/* {
		reverse_proxy api:3001
	}

	# Everything else goes to the Astro web frontend
	handle {
		reverse_proxy web:3000
	}

	# Compression
	encode gzip zstd

	# Logging
	log {
		output stdout
	}
}

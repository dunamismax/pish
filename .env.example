# Pish environment variables
# Copy to .env and fill in real values for production.

NODE_ENV=development

# --- API ---
API_PORT=3001

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgres://pish:pish@localhost:5432/pish

# --- Valkey (Redis-compatible) ---
VALKEY_URL=redis://localhost:6379

# --- MeiliSearch ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=pish-dev-key

# --- Auth ---
# SESSION_SECRET=generate-a-random-secret

# --- OAuth (Arctic) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# --- Email (Resend) ---
# RESEND_API_KEY=
# EMAIL_FROM=noreply@getpish.com

# --- Stripe ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_YEARLY_PRICE_ID=

# --- Sentry ---
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- eBird ---
# EBIRD_API_KEY=

# --- OpenWeatherMap ---
# OPENWEATHER_API_KEY=

# --- Web Push ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@getpish.com

---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Home" description="The all-in-one birding platform. Real-time bird sound ID, crowd-confirmed sighting alerts, community features, and personal stats.">
	<!-- Hero -->
	<section class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 sm:py-28">
		<h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
			One app for <span class="text-primary-600">everything birding</span>
		</h1>
		<p class="mx-auto mt-6 max-w-2xl text-lg text-(--color-text-muted)">
			Real-time sound ID, crowd-confirmed alerts, social community, trip planning,
			gamification, and personal stats. Think Strava meets eBird meets Merlin.
		</p>
		<div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
			<a href="/signup" class="w-full rounded-lg bg-primary-600 px-8 py-3 font-medium text-white hover:bg-primary-700 transition-colors sm:w-auto">
				Get started free
			</a>
			<a href="#features" class="w-full rounded-lg border border-(--color-border) px-8 py-3 font-medium hover:bg-(--color-bg-alt) transition-colors sm:w-auto">
				Learn more
			</a>
		</div>
	</section>

	<!-- Features -->
	<section id="features" class="border-t border-(--color-border) bg-(--color-bg-alt)">
		<div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
			<h2 class="text-center text-2xl font-bold sm:text-3xl">Built for serious birders</h2>
			<p class="mx-auto mt-3 max-w-xl text-center text-(--color-text-muted)">
				Everything you need to identify, track, and share your birding adventures.
			</p>

			<div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				<div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-6">
					<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
						<svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
						</svg>
					</div>
					<h3 class="font-semibold">Live Sighting Map</h3>
					<p class="mt-2 text-sm text-(--color-text-muted)">
						See bird sightings in real time on an interactive map. Filter by rarity, species, and confirmation status.
					</p>
				</div>

				<div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-6">
					<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
						<svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
						</svg>
					</div>
					<h3 class="font-semibold">Smart Field Guide</h3>
					<p class="mt-2 text-sm text-(--color-text-muted)">
						Search thousands of species with "likely here now" predictions based on your location and current month.
					</p>
				</div>

				<div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-6">
					<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
						<svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
						</svg>
					</div>
					<h3 class="font-semibold">Custom Alerts</h3>
					<p class="mt-2 text-sm text-(--color-text-muted)">
						Get notified when rare species are spotted near you. Set alerts by species, rarity level, and distance.
					</p>
				</div>

				<div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-6">
					<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
						<svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
						</svg>
					</div>
					<h3 class="font-semibold">Crowd Confirmation</h3>
					<p class="mt-2 text-sm text-(--color-text-muted)">
						Community-powered verification system. Rare sightings get confirmed by other birders for reliable data.
					</p>
				</div>

				<div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-6">
					<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
						<svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
						</svg>
					</div>
					<h3 class="font-semibold">Social Feed</h3>
					<p class="mt-2 text-sm text-(--color-text-muted)">
						Follow birders, share sightings, and build your community. Celebrate rare finds together.
					</p>
				</div>

				<div class="rounded-xl border border-(--color-border) bg-(--color-bg) p-6">
					<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
						<svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
						</svg>
					</div>
					<h3 class="font-semibold">Personal Stats</h3>
					<p class="mt-2 text-sm text-(--color-text-muted)">
						Track your life list, year list, and birding statistics. See trends and compete on leaderboards.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6">
		<h2 class="text-2xl font-bold sm:text-3xl">Ready to start birding?</h2>
		<p class="mx-auto mt-3 max-w-md text-(--color-text-muted)">
			Join the Pish community and never miss a rare sighting again.
		</p>
		<a
			href="/signup"
			class="mt-8 inline-block rounded-lg bg-primary-600 px-8 py-3 font-medium text-white hover:bg-primary-700 transition-colors"
		>
			Create free account
		</a>
	</section>
</PublicLayout>

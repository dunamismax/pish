---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Home" description="The all-in-one birding platform. Real-time bird sound ID, crowd-confirmed sighting alerts, community features, and personal stats.">
	<section class="mx-auto max-w-4xl px-6 py-24 text-center">
		<h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
			One app for <span class="text-[var(--color-primary-600)]">everything birding</span>
		</h1>
		<p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-muted)]">
			Real-time sound ID, crowd-confirmed alerts, social community, trip planning,
			gamification, and personal stats. Think Strava meets eBird meets Merlin.
		</p>
		<div class="mt-10 flex items-center justify-center gap-4">
			<a href="/signup" class="rounded-lg bg-[var(--color-primary-600)] px-6 py-3 font-medium text-white hover:bg-[var(--color-primary-700)]">
				Get started free
			</a>
			<a href="/about" class="rounded-lg border border-[var(--color-border)] px-6 py-3 font-medium hover:bg-[var(--color-bg-alt)]">
				Learn more
			</a>
		</div>
	</section>
</PublicLayout>

---
import AppLayout from "../../../layouts/AppLayout.astro";
import SpeciesSearch from "../../../components/SpeciesSearch.vue";
import LikelyHereNow from "../../../components/LikelyHereNow.vue";
---

<AppLayout title="Field Guide">
	<div class="mx-auto max-w-3xl space-y-8">
		<!-- Search -->
		<div>
			<p class="mb-3 text-sm text-(--color-text-muted)">
				Search thousands of bird species. Get details on identification, range, and frequency.
			</p>
			<SpeciesSearch client:load />
		</div>

		<!-- Likely here now -->
		<LikelyHereNow client:load />
	</div>
</AppLayout>

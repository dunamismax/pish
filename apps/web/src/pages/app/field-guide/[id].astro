---
import AppLayout from "../../../layouts/AppLayout.astro";
import FrequencyChart from "../../../components/FrequencyChart.vue";

const { id } = Astro.params;

// Fetch species data server-side
const apiBase = import.meta.env.API_URL || "http://localhost:3001";
let species: Record<string, unknown> | null = null;

try {
	const res = await fetch(`${apiBase}/api/species/${id}`);
	const json = await res.json();
	if (json.ok) {
		species = json.data;
	}
} catch {
	// Species not found or API unreachable
}

if (!species) {
	return Astro.redirect("/app/field-guide");
}

const commonName = species.commonName as string;
const scientificName = species.scientificName as string;
const familyCommonName = species.familyCommonName as string | null;
const familyScientificName = species.familyScientificName as string | null;
const order = species.order as string | null;
const category = species.category as string | null;
const speciesCode = species.speciesCode as string;
---

<AppLayout title={commonName}>
	<div class="mx-auto max-w-3xl">
		<!-- Back link -->
		<a
			href="/app/field-guide"
			class="mb-6 inline-flex items-center gap-1 text-sm text-(--color-text-muted) hover:text-(--color-text)"
		>
			<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
			</svg>
			Back to Field Guide
		</a>

		<!-- Species header -->
		<div class="mb-8">
			<div class="flex items-start justify-between">
				<div>
					<h1 class="text-2xl font-bold">{commonName}</h1>
					<p class="mt-1 text-base italic text-(--color-text-muted)">{scientificName}</p>
				</div>
				<span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-700 uppercase">
					{speciesCode}
				</span>
			</div>
		</div>

		<div class="grid gap-6 md:grid-cols-2">
			<!-- Taxonomy card -->
			<div class="rounded-xl border border-(--color-border) p-5">
				<h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-(--color-text-muted)">Taxonomy</h2>
				<dl class="space-y-3">
					{order && (
						<div>
							<dt class="text-xs text-(--color-text-muted)">Order</dt>
							<dd class="text-sm font-medium">{order}</dd>
						</div>
					)}
					{familyCommonName && (
						<div>
							<dt class="text-xs text-(--color-text-muted)">Family</dt>
							<dd class="text-sm font-medium">{familyCommonName}</dd>
							{familyScientificName && (
								<dd class="text-xs italic text-(--color-text-muted)">{familyScientificName}</dd>
							)}
						</div>
					)}
					{category && (
						<div>
							<dt class="text-xs text-(--color-text-muted)">Category</dt>
							<dd class="text-sm font-medium capitalize">{category}</dd>
						</div>
					)}
				</dl>
			</div>

			<!-- Frequency chart -->
			<div class="rounded-xl border border-(--color-border) p-5">
				<FrequencyChart speciesId={id!} client:load />
			</div>
		</div>

		<!-- Similar species placeholder -->
		<div class="mt-6 rounded-xl border border-(--color-border) p-5">
			<h2 class="mb-2 text-sm font-semibold uppercase tracking-wider text-(--color-text-muted)">Field Notes</h2>
			<p class="text-sm text-(--color-text-muted)">
				Detailed field marks, habitat, and similar species information will be available as community data grows.
				Check eBird for current range maps and recent sightings of {commonName}.
			</p>
		</div>
	</div>
</AppLayout>

---
import PublicLayout from "../layouts/PublicLayout.astro";

const token = Astro.url.searchParams.get("token");
---

<PublicLayout title="Reset Password">
	<section class="mx-auto max-w-sm px-6 py-24">
		{!token ? (
			<div class="text-center">
				<h1 class="text-2xl font-bold">Invalid reset link</h1>
				<p class="mt-2 text-sm text-(--color-text-muted)">
					This password reset link is invalid or has expired.
				</p>
				<a href="/forgot-password" class="mt-4 inline-block text-sm text-primary-600 hover:underline">
					Request a new reset link
				</a>
			</div>
		) : (
			<div>
				<h1 class="text-2xl font-bold">Set new password</h1>
				<p class="mt-2 text-sm text-(--color-text-muted)">Enter your new password below.</p>
				<form class="mt-8 flex flex-col gap-4" method="POST" action="/api/auth/reset-password">
					<input type="hidden" name="token" value={token} />
					<label class="flex flex-col gap-1">
						<span class="text-sm font-medium">New password</span>
						<input
							type="password"
							name="password"
							required
							minlength="8"
							class="rounded-lg border border-(--color-border) bg-(--color-bg) px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						/>
					</label>
					<label class="flex flex-col gap-1">
						<span class="text-sm font-medium">Confirm password</span>
						<input
							type="password"
							name="confirmPassword"
							required
							minlength="8"
							class="rounded-lg border border-(--color-border) bg-(--color-bg) px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						/>
					</label>
					<button
						type="submit"
						class="rounded-lg bg-primary-600 px-4 py-2 font-medium text-white hover:bg-primary-700 transition-colors"
					>
						Reset password
					</button>
				</form>
			</div>
		)}
	</section>
</PublicLayout>

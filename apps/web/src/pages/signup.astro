---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Sign Up">
	<section class="mx-auto max-w-sm px-6 py-24">
		<h1 class="text-2xl font-bold">Create your Pish account</h1>
		<p class="mt-2 text-sm text-[var(--color-text-muted)]">Join the birding community.</p>
		<form class="mt-8 flex flex-col gap-4" method="POST" action="/api/auth/signup">
			<label class="flex flex-col gap-1">
				<span class="text-sm font-medium">Username</span>
				<input type="text" name="username" required minlength="3" maxlength="30" pattern="^[a-zA-Z0-9_-]+$" class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 text-sm" />
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-sm font-medium">Email</span>
				<input type="email" name="email" required class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 text-sm" />
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-sm font-medium">Password</span>
				<input type="password" name="password" required minlength="8" class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 text-sm" />
			</label>
			<button type="submit" class="rounded-lg bg-[var(--color-primary-600)] px-4 py-2 font-medium text-white hover:bg-[var(--color-primary-700)]">
				Create account
			</button>
		</form>
		<p class="mt-6 text-center text-sm text-[var(--color-text-muted)]">
			Already have an account? <a href="/signin" class="text-[var(--color-primary-600)] hover:underline">Sign in</a>
		</p>
	</section>
</PublicLayout>

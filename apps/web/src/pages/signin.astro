---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Sign In">
	<section class="mx-auto max-w-sm px-6 py-24">
		<h1 class="text-2xl font-bold">Sign in to Pish</h1>
		<p class="mt-2 text-sm text-(--color-text-muted)">Welcome back.</p>
		<form class="mt-8 flex flex-col gap-4" method="POST" action="/api/auth/signin">
			<label class="flex flex-col gap-1">
				<span class="text-sm font-medium">Email</span>
				<input
					type="email"
					name="email"
					required
					class="rounded-lg border border-(--color-border) bg-(--color-bg) px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
				/>
			</label>
			<label class="flex flex-col gap-1">
				<span class="text-sm font-medium">Password</span>
				<input
					type="password"
					name="password"
					required
					class="rounded-lg border border-(--color-border) bg-(--color-bg) px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
				/>
			</label>
			<div class="flex justify-end">
				<a href="/forgot-password" class="text-xs text-primary-600 hover:underline">Forgot password?</a>
			</div>
			<button
				type="submit"
				class="rounded-lg bg-primary-600 px-4 py-2 font-medium text-white hover:bg-primary-700 transition-colors"
			>
				Sign in
			</button>
		</form>
		<p class="mt-6 text-center text-sm text-(--color-text-muted)">
			Don't have an account? <a href="/signup" class="text-primary-600 hover:underline">Sign up</a>
		</p>
	</section>
</PublicLayout>

---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Forgot Password">
	<section class="mx-auto max-w-sm px-6 py-24">
		<h1 class="text-2xl font-bold">Reset your password</h1>
		<p class="mt-2 text-sm text-(--color-text-muted)">
			Enter your email and we'll send you a reset link.
		</p>
		<form class="mt-8 flex flex-col gap-4" method="POST" action="/api/auth/forgot-password">
			<label class="flex flex-col gap-1">
				<span class="text-sm font-medium">Email</span>
				<input
					type="email"
					name="email"
					required
					class="rounded-lg border border-(--color-border) bg-(--color-bg) px-3 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
				/>
			</label>
			<button
				type="submit"
				class="rounded-lg bg-primary-600 px-4 py-2 font-medium text-white hover:bg-primary-700 transition-colors"
			>
				Send reset link
			</button>
		</form>
		<p class="mt-6 text-center text-sm text-(--color-text-muted)">
			Remember your password? <a href="/signin" class="text-primary-600 hover:underline">Sign in</a>
		</p>
	</section>
</PublicLayout>

---
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title: string;
	description?: string;
	fullScreen?: boolean;
}

const { title, description, fullScreen = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
	{ href: "/app/map", label: "Map", icon: "map" },
	{ href: "/app/dashboard", label: "Home", icon: "home" },
	{ href: "/app/field-guide", label: "Guide", icon: "book" },
	{ href: "/app/feed", label: "Feed", icon: "activity" },
	{ href: "/app/profile", label: "Profile", icon: "user" },
];

function isActive(href: string): boolean {
	return currentPath === href || currentPath.startsWith(href + "/");
}
---

<BaseLayout title={title} description={description}>
	<div class="flex min-h-screen">
		<!-- Desktop sidebar -->
		<aside class="hidden w-64 flex-shrink-0 border-r border-(--color-border) bg-(--color-bg-alt) md:flex md:flex-col">
			<div class="p-6">
				<a href="/app" class="text-xl font-bold text-primary-600">Pish</a>
			</div>
			<nav class="flex flex-1 flex-col gap-1 px-3">
				{navItems.map((item) => (
					<a
						href={item.href}
						class:list={[
							"flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
							isActive(item.href)
								? "bg-primary-100 text-primary-700 font-medium"
								: "text-(--color-text-muted) hover:bg-(--color-border) hover:text-(--color-text)",
						]}
					>
						<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							{item.icon === "map" && <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />}
							{item.icon === "home" && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />}
							{item.icon === "book" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />}
							{item.icon === "activity" && <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />}
							{item.icon === "user" && <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />}
						</svg>
						{item.label}
					</a>
				))}
			</nav>
			<div class="border-t border-(--color-border) p-4">
				<a href="/api/auth/signout" class="flex items-center gap-2 text-sm text-(--color-text-muted) hover:text-(--color-text)">
					<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
					</svg>
					Sign out
				</a>
			</div>
		</aside>

		<!-- Main content area -->
		<div class="flex flex-1 flex-col pb-16 md:pb-0">
			{!fullScreen && (
				<header class="border-b border-(--color-border) px-4 py-3 md:px-6 md:py-4">
					<div class="flex items-center justify-between">
						<h1 class="text-lg font-semibold">{title}</h1>
					</div>
				</header>
			)}
			<main class:list={[fullScreen ? "flex-1" : "flex-1 p-4 md:p-6"]}>
				<slot />
			</main>
		</div>

		<!-- Mobile tab bar -->
		<nav class="fixed bottom-0 left-0 right-0 z-50 flex border-t border-(--color-border) bg-(--color-bg) md:hidden">
			{navItems.map((item) => (
				<a
					href={item.href}
					class:list={[
						"flex flex-1 flex-col items-center gap-0.5 py-2 text-[10px]",
						isActive(item.href)
							? "text-primary-600 font-medium"
							: "text-(--color-text-muted)",
					]}
				>
					<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
						{item.icon === "map" && <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />}
						{item.icon === "home" && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />}
						{item.icon === "book" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />}
						{item.icon === "activity" && <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />}
						{item.icon === "user" && <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />}
					</svg>
					{item.label}
				</a>
			))}
		</nav>
	</div>
</BaseLayout>
